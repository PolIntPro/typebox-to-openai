{
    "name": "typebox-to-openai",
    "version": "2.0.0",
    "description": "Convert Typebox schema to OpenAI API schema for structured output",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist",
        "!dist/tsconfig.tsbuildinfo"
    ],
    "scripts": {
        "test": "vitest run",
        "lint": "eslint .",
        "prettify": "pnpx prettier -w .",
        "build": "tsc",
        "prepare": "pnpm run build"
    },
    "type": "module",
    "keywords": [
        "typebox",
        "openai",
        "schema",
        "structured-output",
        "json-schema",
        "typebox-openai"
    ],
    "author": "",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/PolIntPro/typebox-to-openai.git"
    },
    "homepage": "https://github.com/PolIntPro/typebox-to-openai",
    "bugs": {
        "url": "https://github.com/PolIntPro/typebox-to-openai/issues"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@types/node": "^24.10.9",
        "eslint": "^9.39.2",
        "openai": "^4.104.0",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.53.1",
        "vitest": "^3.2.4"
    },
    "peerDependencies": {
        "typebox": "^1.1.6"
    },
    "packageManager": "pnpm@10.23.0"
}
